# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# envs
.venv/
venv/
env/

# tooling
.pytest_cache/
.pytest-tmp/
.mypy_cache/
.ruff_cache/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# scratch — temporary screen captures from ad-hoc runs (keep research/captures/ which is curated)
research/_mbx.*
*.tmp

# URA raw batch cache (rolling ~5y of caveats, MBs, refetchable) — normalized output
# researcher/sources/ura_transactions.json IS versioned so backtests are reproducible.
research/ura_cache/
# per-run backtest artifacts (regenerated by researcher.backtest.run / run_landed)
researcher/backtest/results_condo.json
researcher/backtest/results_landed.json
researcher/backtest/rows_landed_*.json
# generated HTML reports — regenerable artifacts, never source. Every builder writes here
# AND syncs to G:\My Drive\004 RES\REsearch_Reports (deliverables/report_out.py).
# They used to fall back into the TRACKED deliverables/ when the Drive was unmounted,
# which is how a 60 KB report blob got committed. Don't reintroduce that.
reports/
# and never again via the old fallback path (build_*.py used to write here)
deliverables/*.html
# secrets — never commit the URA access key (private repo is NOT safe for secrets)
research/.secrets/
# normalized URA store: 71MB, regenerable. A frozen gzipped snapshot is committed
# separately (researcher/sources/snapshots/) for backtest reproducibility.
researcher/sources/ura_transactions.json
